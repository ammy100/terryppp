{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores artist profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID." },
        "displayName": { "type": "string", "description": "Artist's display name." },
        "email": { "type": "string", "format": "email", "description": "Artist's email address." },
        "photoURL": { "type": "string", "format": "uri", "description": "Artist's profile photo URL." },
        "bio": { "type": "string", "description": "Artist's biography." },
        "role": { "type": "string", "enum": ["artist", "admin"], "description": "User role." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Profile creation timestamp." }
      },
      "required": ["uid", "displayName", "email", "role"]
    },
    "Exhibition": {
      "title": "Exhibition",
      "description": "Represents a virtual art exhibition.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique exhibition ID." },
        "artistUid": { "type": "string", "description": "UID of the artist who created it." },
        "title": { "type": "string", "description": "Exhibition title." },
        "description": { "type": "string", "description": "Exhibition description." },
        "type": { "type": "string", "enum": ["Virtual Reality", "Augmented Reality", "Physical Gallery"], "description": "Type of exhibition." },
        "coverImage": { "type": "string", "format": "uri", "description": "Cover image URL." },
        "status": { "type": "string", "enum": ["draft", "published", "archived"], "description": "Current status." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp." }
      },
      "required": ["artistUid", "title", "type", "status"]
    },
    "Artwork": {
      "title": "Artwork",
      "description": "An individual piece of art within an exhibition.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique artwork ID." },
        "exhibitionId": { "type": "string", "description": "ID of the parent exhibition." },
        "artistUid": { "type": "string", "description": "UID of the artist." },
        "title": { "type": "string", "description": "Artwork title." },
        "description": { "type": "string", "description": "Artwork description." },
        "imageUrl": { "type": "string", "format": "uri", "description": "Image URL." },
        "analysis": { "type": "string", "description": "Gemini-generated analysis of the artwork." },
        "metadata": {
          "type": "object",
          "properties": {
            "iso": { "type": "string" },
            "aperture": { "type": "string" },
            "shutter": { "type": "string" },
            "focalLength": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["exhibitionId", "artistUid", "imageUrl"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "Artist profiles."
    },
    "/exhibitions/{exhibitionId}": {
      "schema": "Exhibition",
      "description": "Virtual exhibitions."
    },
    "/exhibitions/{exhibitionId}/artworks/{artworkId}": {
      "schema": "Artwork",
      "description": "Artworks within an exhibition."
    }
  }
}
